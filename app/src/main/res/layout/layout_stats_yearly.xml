<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F0F2F5">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="16dp"
            android:paddingHorizontal="2dp">

            <!-- Header với padding riêng để không bị sát mép -->
            <ImageView
                android:id="@+id/ivYearlyHeader"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:paddingHorizontal="14dp"
                android:scaleType="fitCenter"
                android:src="@drawable/header"
                android:contentDescription="Habit Tracker" />

            <!-- Year Selector với padding riêng -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivPrevYear"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="#FF8A8A" />

                <TextView
                    android:id="@+id/tvYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:background="#FFF9C4"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="2dp"
                    android:text="2026"
                    android:textColor="#000000"
                    android:textStyle="bold|italic"
                    android:textSize="18sp" />

                <ImageView
                    android:id="@+id/ivNextYear"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FF8A8A" />
            </LinearLayout>

            <!-- RecyclerView Habit List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvYearlyHabits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.core.widget.NestedScrollView>