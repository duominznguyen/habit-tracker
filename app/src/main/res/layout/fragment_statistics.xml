<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Tab Header -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        app:tabIndicatorColor="#FF8A8A"
        app:tabIndicatorHeight="3dp"
        app:tabIndicatorFullWidth="false"
        app:tabIndicatorGravity="bottom"
        app:tabRippleColor="@android:color/transparent"
        app:tabSelectedTextColor="#000000"
        app:tabTextColor="#A0A0A0"
        app:tabTextAppearance="@style/StatsTabText"
        app:tabMode="scrollable"
        app:tabInlineLabel="true"
        android:background="@android:color/transparent"/>

    <!-- Placeholder for Content -->
    <FrameLayout
        android:id="@+id/statsContentPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvPlaceholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Content for Weekly will appear here"
            android:textColor="#A0A0A0"/>

    </FrameLayout>

</LinearLayout>