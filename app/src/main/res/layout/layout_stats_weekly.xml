<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:padding="2dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top Image -->
        <ImageView
            android:id="@+id/ivStatsHeader"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:scaleType="fitCenter"
            android:src="@drawable/header"
            android:contentDescription="Habit Tracker Header" />

        <!-- Week Navigation -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivPrevWeek"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:src="@drawable/ic_chevron_left" />

            <TextView
                android:id="@+id/tvWeekRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="#FFF9C4"
                android:paddingHorizontal="8dp"
                android:text="13-04 ~ 19-04"
                android:textColor="#000000"
                android:textStyle="bold|italic" />

            <ImageView
                android:id="@+id/ivNextWeek"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <!-- Table Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_stats_card">

            <!-- Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal">

                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="3" />
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><TextView style="@style/StatsHeaderCell" android:text="M" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><TextView style="@style/StatsHeaderCell" android:text="T" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><TextView style="@style/StatsHeaderCell" android:text="W" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><TextView style="@style/StatsHeaderCell" android:text="T" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><TextView style="@style/StatsHeaderCell" android:text="F" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><TextView style="@style/StatsHeaderCell" android:text="S" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><TextView style="@style/StatsHeaderCell" android:text="S" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer" />
            </LinearLayout>

            <View style="@style/StatsHorizontalDivider" />

            <!-- Habit List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWeeklyHabits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- Best Day Row -->
            <LinearLayout
                android:id="@+id/layoutBestDayRow"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="#FFFDE7">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="3"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:text="BestDay"
                    android:textColor="#000000"
                    android:textSize="12sp" />

                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><ImageView android:id="@+id/ivBestM" style="@style/StatsBestCell" android:visibility="invisible" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><ImageView android:id="@+id/ivBestT" style="@style/StatsBestCell" android:visibility="invisible" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><ImageView android:id="@+id/ivBestW" style="@style/StatsBestCell" android:visibility="invisible" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><ImageView android:id="@+id/ivBestTh" style="@style/StatsBestCell" android:visibility="invisible" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><ImageView android:id="@+id/ivBestF" style="@style/StatsBestCell" android:visibility="invisible" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><ImageView android:id="@+id/ivBestS" style="@style/StatsBestCell" android:visibility="invisible" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer"><ImageView android:id="@+id/ivBestSu" style="@style/StatsBestCell" android:visibility="invisible" /></FrameLayout>
                <View style="@style/StatsVerticalDivider" />
                <FrameLayout style="@style/StatsColumnContainer" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>